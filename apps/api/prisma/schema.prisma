generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 租户表
model Tenant {
  id        String   @id @default(uuid())
  name      String
  code      String  @unique
  status    String   @default("active")
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  roles Role[]
  warehouses Warehouse[]
  stores Store[]
  productCategories ProductCategory[]
  products Product[]
  customers Customer[]
  suppliers Supplier[]
  accounts Account[]
  accountSubjects AccountSubject[]
  purchaseOrders PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  purchaseStockIns PurchaseStockIn[]
  purchaseStockInItems PurchaseStockInItem[]
  saleOrders SaleOrder[]
  saleOrderItems SaleOrderItem[]
  saleStockOuts SaleStockOut[]
  saleStockOutItems SaleStockOutItem[]
  inventories Inventory[]
  inventoryLogs InventoryLog[]
  stockChecks StockCheck[]
  stockCheckItems StockCheckItem[]
  stockTransfers StockTransfer[]
  stockTransferItems StockTransferItem[]
  vouchers Voucher[]
  voucherItems VoucherItem[]
  payments Payment[]
  billSequences BillSequence[]
  operationLogs OperationLog[]
}

// 用户表
model User {
  id           String   @id @default(uuid())
  tenantId     String
  username     String
  passwordHash String
  realName     String?
  phone        String?
  email        String?
  status       String   @default("active")
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]
  userStores UserStore[]

  @@unique([tenantId, username])
  @@map("user")
}

// 角色表
model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]
  userRoles UserRole[]

  @@unique([tenantId, code])
  @@map("role")
}

// 角色权限关联
model RolePermission {
  id              String   @id @default(uuid())
  roleId          String
  permissionCode  String
  createdAt       DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id])

  @@map("role_permission")
}

// 用户角色关联
model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_role")
}

// 仓库表
model Warehouse {
  id         String   @id @default(uuid())
  tenantId   String
  code       String
  name       String
  address    String?
  principal  String?
  sortOrder  Int      @default(0)
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  purchaseStockIns PurchaseStockIn[]
  saleOrders SaleOrder[]
  saleOrderItems SaleOrderItem[]
  saleStockOuts SaleStockOut[]
  inventories Inventory[]
  inventoryLogs InventoryLog[]
  stockChecks StockCheck[]
  stockTransfersFrom StockTransfer[] @relation("FromWarehouse")
  stockTransfersTo StockTransfer[] @relation("ToWarehouse")

  @@unique([tenantId, code])
  @@map("warehouse")
}

// 门店（一个租户可有多个门店，门店下可有多个仓库）
model Store {
  id         String      @id @default(uuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  code       String
  name       String
  address    String?
  phone      String?
  manager    String?
  status     String      @default("active")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  warehouses Warehouse[]
  userStores UserStore[]
  fromTransfers StoreTransfer[] @relation("FromStore")
  toTransfers   StoreTransfer[] @relation("ToStore")
  saleOrders SaleOrder[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@map("store")
}

// 用户归属门店（多对多）
model UserStore {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  role      String   @default("staff") // staff | manager
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@map("user_store")
}

// 店间调拨单
model StoreTransfer {
  id           String   @id @default(uuid())
  tenantId     String
  transferNo   String
  fromStoreId  String
  toStoreId    String
  fromStore    Store    @relation("FromStore", fields: [fromStoreId], references: [id])
  toStore      Store    @relation("ToStore", fields: [toStoreId], references: [id])
  status       String   @default("pending")
  remark       String?
  creatorId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        StoreTransferItem[]

  @@unique([tenantId, transferNo])
  @@map("store_transfer")
}

model StoreTransferItem {
  id              String   @id @default(uuid())
  storeTransferId String
  storeTransfer   StoreTransfer @relation(fields: [storeTransferId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  fromWarehouseId String?
  toWarehouseId   String?
  quantity        Int
  status          String   @default("pending")
  @@map("store_transfer_item")
}

// 商品分类表
model ProductCategory {
  id       String  @id @default(uuid())
  tenantId String
  parentId String?
  name     String
  sortOrder Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  parent ProductCategory? @relation("ParentChild", fields: [parentId], references: [id])
  children ProductCategory[] @relation("ParentChild")
  products Product[]

  @@unique([tenantId, parentId, name])
  @@map("product_category")
}

// 商品表
model Product {
  id            String  @id @default(uuid())
  tenantId      String
  categoryId    String?
  code          String
  name          String
  spec          String?
  unit          String?
  purchasePrice Decimal? @db.Decimal(15, 2)
  salePrice     Decimal? @db.Decimal(15, 2)
  costPrice     Decimal? @db.Decimal(15, 2)
  minStock      Int     @default(0)
  maxStock      Int     @default(0)
  status        String  @default("active")
  imageUrl      String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  category ProductCategory? @relation(fields: [categoryId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  purchaseStockInItems PurchaseStockInItem[]
  saleOrderItems SaleOrderItem[]
  saleStockOutItems SaleStockOutItem[]
  inventories Inventory[]
  inventoryLogs InventoryLog[]
  stockCheckItems StockCheckItem[]
  stockTransferItems StockTransferItem[]
  storeTransferItems StoreTransferItem[]

  @@unique([tenantId, code])
  @@map("product")
}

// 客户表
model Customer {
  id           String  @id @default(uuid())
  tenantId     String
  code         String
  name         String
  contact      String?
  phone        String?
  mobile       String?
  email        String?
  address      String?
  customerType String?
  creditLimit  Decimal? @db.Decimal(15, 2)
  status       String  @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  saleOrders SaleOrder[]
  saleStockOuts SaleStockOut[]
  payments Payment[]

  @@unique([tenantId, code])
  @@map("customer")
}

// 供应商表
model Supplier {
  id         String  @id @default(uuid())
  tenantId   String
  code       String
  name       String
  contact    String?
  phone      String?
  mobile     String?
  email      String?
  address    String?
  bankName   String?
  bankAccount String?
  taxNo      String?
  status     String  @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  purchaseStockIns PurchaseStockIn[]
  payments Payment[]

  @@unique([tenantId, code])
  @@map("supplier")
}

// 账户表
model Account {
  id             String  @id @default(uuid())
  tenantId       String
  code           String
  name           String
  type           String?
  bankName       String?
  bankAccount    String?
  initialBalance Decimal @default(0) @db.Decimal(15, 2)
  currentBalance Decimal @default(0) @db.Decimal(15, 2)
  status         String  @default("active")
  isDefault      Boolean @default(false)
  sortOrder      Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@unique([tenantId, code])
  @@map("account")
}

// 会计科目表
model AccountSubject {
  id        String  @id @default(uuid())
  tenantId  String
  code      String
  name      String
  type      String?
  direction String?
  parentId  String?
  isDetail  Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  parent AccountSubject? @relation("SubjectParent", fields: [parentId], references: [id])
  children AccountSubject[] @relation("SubjectParent")
  voucherItems VoucherItem[]

  @@unique([tenantId, code])
  @@map("account_subject")
}

// 采购订单
model PurchaseOrder {
  id           String   @id @default(uuid())
  tenantId     String
  orderNo      String
  orderDate    DateTime
  supplierId   String
  warehouseId  String
  storeId     String?   // 所属门店（从仓库派生，可选）
  contact      String?
  phone        String?
  totalAmount  Decimal  @default(0) @db.Decimal(15, 2)
  paidAmount   Decimal  @default(0) @db.Decimal(15, 2)
  status       String   @default("pending")
  deliveryDate DateTime?
  remark       String?
  createdById  String?
  auditedById  String?
  auditedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  store Store? @relation(fields: [storeId], references: [id])
  items PurchaseOrderItem[]

  @@unique([tenantId, orderNo])
  @@map("purchase_order")
}

// 采购订单明细
model PurchaseOrderItem {
  id             String  @id @default(uuid())
  tenantId       String
  orderId        String
  productId      String
  warehouseId    String
  quantity       Decimal @db.Decimal(15, 4)
  price          Decimal @db.Decimal(15, 2)
  amount         Decimal @db.Decimal(15, 2)
  receivedQty    Decimal @default(0) @db.Decimal(15, 4)
  taxRate        Decimal @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal @default(0) @db.Decimal(15, 2)
  remark         String?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order PurchaseOrder @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("purchase_order_item")
}

// 采购入库单
model PurchaseStockIn {
  id           String   @id @default(uuid())
  tenantId     String
  orderNo      String
  stockInDate  DateTime
  supplierId   String
  warehouseId  String
  totalAmount  Decimal  @default(0) @db.Decimal(15, 2)
  paidAmount   Decimal  @default(0) @db.Decimal(15, 2)
  status       String   @default("pending")
  remark       String?
  createdById   String?
  auditedById   String?
  auditedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  items PurchaseStockInItem[]

  @@unique([tenantId, orderNo])
  @@map("purchase_stock_in")
}

// 采购入库明细
model PurchaseStockInItem {
  id                  String  @id @default(uuid())
  tenantId            String
  stockInId           String
  productId           String
  purchaseOrderId     String?
  purchaseOrderItemId String?
  quantity            Decimal @db.Decimal(15, 4)
  price               Decimal @db.Decimal(15, 2)
  amount              Decimal @db.Decimal(15, 2)
  createdAt           DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  stockIn PurchaseStockIn @relation(fields: [stockInId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("purchase_stock_in_item")
}

// 销售订单
model SaleOrder {
  id             String   @id @default(uuid())
  tenantId       String
  orderNo        String
  orderDate      DateTime
  customerId     String
  warehouseId    String
  storeId       String?   // 所属门店（从仓库派生，可选）
  contact        String?
  phone          String?
  totalAmount    Decimal  @default(0) @db.Decimal(15, 2)
  receivedAmount Decimal  @default(0) @db.Decimal(15, 2)
  status         String   @default("pending")
  deliveryDate   DateTime?
  remark         String?
  createdById    String?
  auditedById    String?
  auditedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  store Store? @relation(fields: [storeId], references: [id])
  items SaleOrderItem[]

  @@unique([tenantId, orderNo])
  @@map("sale_order")
}

// 销售订单明细
model SaleOrderItem {
  id             String  @id @default(uuid())
  tenantId       String
  orderId        String
  productId      String
  warehouseId    String
  quantity       Decimal @db.Decimal(15, 4)
  price          Decimal @db.Decimal(15, 2)
  amount         Decimal @db.Decimal(15, 2)
  deliveredQty   Decimal @default(0) @db.Decimal(15, 4)
  taxRate        Decimal @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal @default(0) @db.Decimal(15, 2)
  remark         String?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order SaleOrder @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("sale_order_item")
}

// 销售出库单
model SaleStockOut {
  id              String   @id @default(uuid())
  tenantId        String
  orderNo         String
  stockOutDate    DateTime
  customerId      String
  warehouseId     String
  totalAmount     Decimal  @default(0) @db.Decimal(15, 2)
  receivedAmount  Decimal  @default(0) @db.Decimal(15, 2)
  status          String   @default("pending")
  remark          String?
  createdById     String?
  auditedById     String?
  auditedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  items SaleStockOutItem[]

  @@unique([tenantId, orderNo])
  @@map("sale_stock_out")
}

// 销售出库明细
model SaleStockOutItem {
  id              String  @id @default(uuid())
  tenantId        String
  stockOutId      String
  productId       String
  saleOrderId     String?
  saleOrderItemId String?
  quantity        Decimal @db.Decimal(15, 4)
  price           Decimal @db.Decimal(15, 2)
  amount          Decimal @db.Decimal(15, 2)
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  stockOut SaleStockOut @relation(fields: [stockOutId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_stock_out_item")
}

// 库存表
model Inventory {
  id              String  @id @default(uuid())
  tenantId        String
  productId       String
  warehouseId     String
  quantity        Decimal @default(0) @db.Decimal(15, 4)
  frozenQuantity  Decimal @default(0) @db.Decimal(15, 4)
  avgCostPrice    Decimal @default(0) @db.Decimal(15, 2)
  lastInPrice     Decimal? @db.Decimal(15, 2)
  lastOutPrice    Decimal? @db.Decimal(15, 2)
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([tenantId, productId, warehouseId])
  @@map("inventory")
}

// 库存变动日志
model InventoryLog {
  id              String   @id @default(uuid())
  tenantId        String
  productId       String
  warehouseId     String
  businessType    String
  businessId      String
  businessNo      String
  quantity        Decimal
  beforeQuantity  Decimal?
  afterQuantity   Decimal?
  price           Decimal? @db.Decimal(15, 2)
  amount          Decimal? @db.Decimal(15, 2)
  remark          String?
  createdById     String?
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("inventory_log")
}

// 盘点单
model StockCheck {
  id           String   @id @default(uuid())
  tenantId     String
  orderNo      String
  checkDate    DateTime
  warehouseId  String
  totalAmount  Decimal  @default(0) @db.Decimal(15, 2)
  status       String   @default("pending")
  remark       String?
  createdById  String?
  auditedById  String?
  auditedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  items StockCheckItem[]

  @@unique([tenantId, orderNo])
  @@map("stock_check")
}

// 盘点明细
model StockCheckItem {
  id           String  @id @default(uuid())
  tenantId     String
  checkId      String
  productId    String
  bookQuantity Decimal @db.Decimal(15, 4)
  checkQuantity Decimal @db.Decimal(15, 4)
  diffQuantity  Decimal @db.Decimal(15, 4)
  costPrice    Decimal? @db.Decimal(15, 2)
  diffAmount   Decimal? @db.Decimal(15, 2)
  reason       String?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  check StockCheck @relation(fields: [checkId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("stock_check_item")
}

// 调拨单
model StockTransfer {
  id              String   @id @default(uuid())
  tenantId        String
  orderNo         String
  transferDate    DateTime
  fromWarehouseId String
  toWarehouseId   String
  totalAmount     Decimal  @default(0) @db.Decimal(15, 2)
  status          String   @default("pending")
  remark          String?
  createdById     String?
  auditedById     String?
  auditedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  fromWarehouse Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  items StockTransferItem[]

  @@unique([tenantId, orderNo])
  @@map("stock_transfer")
}

// 调拨明细
model StockTransferItem {
  id          String  @id @default(uuid())
  tenantId    String
  transferId  String
  productId   String
  quantity    Decimal @db.Decimal(15, 4)
  costPrice  Decimal? @db.Decimal(15, 2)
  amount     Decimal? @db.Decimal(15, 2)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  transfer StockTransfer @relation(fields: [transferId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("stock_transfer_item")
}

// 凭证主表
model Voucher {
  id           String   @id @default(uuid())
  tenantId     String
  voucherNo    String
  voucherDate  DateTime
  voucherType  String   @default("记")
  totalDebit   Decimal  @default(0) @db.Decimal(15, 2)
  totalCredit  Decimal  @default(0) @db.Decimal(15, 2)
  attachmentCount Int   @default(0)
  status       String   @default("draft")
  remark       String?
  createdById  String?
  auditedById  String?
  postedById   String?
  auditedAt    DateTime?
  postedAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  items VoucherItem[]

  @@unique([tenantId, voucherNo])
  @@map("voucher")
}

// 凭证分录
model VoucherItem {
  id         String  @id @default(uuid())
  tenantId   String
  voucherId  String
  accountId  String
  direction  String
  amount     Decimal @db.Decimal(15, 2)
  summary    String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  voucher Voucher @relation(fields: [voucherId], references: [id])
  account AccountSubject @relation(fields: [accountId], references: [id])

  @@map("voucher_item")
}

// 收付款单
model Payment {
  id                  String   @id @default(uuid())
  tenantId            String
  paymentNo           String
  paymentDate         DateTime
  paymentType         String
  amount              Decimal  @db.Decimal(15, 2)
  accountId           String
  customerId          String?
  supplierId          String?
  relateBusinessType  String?
  relateBusinessId    String?
  relateBusinessNo    String?
  status              String   @default("pending")
  remark              String?
  createdById         String?
  auditedById         String?
  auditedAt           DateTime?
  createdAt           DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([tenantId, paymentNo])
  @@map("payment")
}

// 单据编号规则
model BillSequence {
  id         String   @id @default(uuid())
  tenantId   String
  billType   String
  prefix     String?
  dateFormat String?
  seqLength  Int      @default(4)
  currentSeq Int      @default(0)
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, billType])
  @@map("bill_sequence")
}

// 操作日志
model OperationLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  entityNo   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("operation_log")
}
